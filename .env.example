# LLM Provider Configuration
# Support Anthropic API or compatible providers (e.g. OpenRouter)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL_ID=MiniMax-M2.5

# Optional: custom base URL for API-compatible providers
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Telegram (optional, for s04_channels.py)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Feishu / Lark (optional, for s04_channels.py)
# FEISHU_APP_ID=your_feishu_app_id_here
# FEISHU_APP_SECRET=your_feishu_app_secret_here
# FEISHU_DOMAIN=feishu    # "feishu" for domestic, "lark" for international

# Heartbeat (optional, for s07_heartbeat_cron.py)
# HEARTBEAT_INTERVAL=1800
# HEARTBEAT_ACTIVE_START=9
# HEARTBEAT_ACTIVE_END=22